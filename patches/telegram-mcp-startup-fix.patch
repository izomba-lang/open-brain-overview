+        # Warm entity cache in the background — StringSession has no persistent
+        # cache, so fetching dialogs once populates it. Do NOT block startup on
+        # this: get_dialogs() can hit a Telegram FLOOD_WAIT, which would delay
+        # the MCP handshake long enough for the client to drop the server.
+        async def _warm_entity_cache() -> None:
+            from telethon.errors import FloodWaitError
+
+            try:
+                await client.get_dialogs()
+                print("Entity cache warmed.", file=sys.stderr)
+            except FloodWaitError as e:
+                print(
+                    f"Skipping cache warm: FLOOD_WAIT for {e.seconds}s. "
+                    "Cache will warm lazily on first use.",
+                    file=sys.stderr,
+                )
+            except Exception as e:
+                print(f"Cache warm failed (non-fatal): {e}", file=sys.stderr)
+
+        asyncio.create_task(_warm_entity_cache())
 
-        print("Telegram client started. Running MCP server...")
+        print("Telegram client started. Running MCP server...", file=sys.stderr)
         # Use the asynchronous entrypoint instead of mcp.run()
         await mcp.run_stdio_async()
     except Exception as e:
